pipeline {
    agent any

    tools {

        jdk 'JDK21'
        maven 'Maven3'

    }

    stages {

        stage ('Checkout') {
            steps {
                git branch: main, url: https://github.com/surajpandey95/employee-service.git
            }
        }
    stage ('Compile') {
        steps {

            sh 'mvn test'
        }
    }

    stage ('Package') {
        steps {
            sh 'mvn clean package'

        }
    }

    stages ('Archive Artifact') {
        steps {
            archiveArtifacts archifacts: 'target/*.jar', fingerprint: true
        
        }

    }
      stages("Sonar Analysis") {
        steps {
            withSonarQubeEnv ('SonarServer') {
            sh 'mvn sonar:sonar'
        }
     }
     stages("Quality Gates") {
        steps {
            timeout(time:5, unit: 'MINUTES') {
                waitForQualityGates abortpipeline: true
            }
        }
     }

      }
      }

      }


    }
}

